BOT_TOKEN=
API_ID=
API_HASH=

# Optional but recommended. If omitted, session encryption is derived from BOT_TOKEN and API_HASH.
SESSION_SECRET=

# Optional admin Telegram chat ID for login/download error logs.
ADMIN_CHAT_ID=

PWTHOR_BASE_URL=https://pwthor.live
ALLOWED_MEDIA_HOSTS=pwthor.live
LOG_LEVEL=INFO
MAX_DOWNLOAD_MB=450
REQUEST_TIMEOUT_SECONDS=30
DOWNLOAD_TIMEOUT_SECONDS=1800
PROGRESS_UPDATE_SECONDS=10
CLEANUP_INTERVAL_SECONDS=600
SESSION_TTL_DAYS=30
MAX_RETRIES=3
MAX_GLOBAL_DOWNLOADS=1
PER_USER_QUEUE_SIZE=3
RATE_LIMIT_MESSAGES=8
RATE_LIMIT_WINDOW_SECONDS=60
